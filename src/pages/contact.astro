---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Work with Me | Chayse Lavallais"
  description="Contact me about sustainability science, life cycle assessment, and carbon accounting work."
>
  <section class="subpage-hero wide-hero">
    <p class="eyebrow">Work with Me</p>
    <h1>Let’s talk about sustainability methods and decisions.</h1>
    <p class="intro">
      Reach out for research conversations, collaboration ideas, or questions
      about life cycle assessment and product carbon footprint methodology.
    </p>
  </section>

  <section class="page-section">
    <div class="service-grid">
      <article>
        <h2>LCA or TEA Project Support</h2>
        <p>
          Assistance scoping, completing, or interpreting life cycle assessment
          and techno-economic analysis work for research or applied projects.
        </p>
      </article>

      <article>
        <h2>LCA Teaching</h2>
        <p>
          Course, workshop, or guest lecture support for students, researchers,
          and teams learning life cycle assessment methods.
        </p>
      </article>

      <article>
        <h2>Scientific and Community Outreach</h2>
        <p>
          Speaking, engagement, and outreach around sustainability science,
          carbon accounting, and environmental decision-making.
        </p>
      </article>

      <article>
        <h2>Research Conversations</h2>
        <p>
          Collaborations, questions, and early-stage ideas related to
          sustainability, LCA, carbon footprints, or chemical systems.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
